@model EFCoreTask.ViewModels.StudentFormViewModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Add Student Record</title>
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; margin: 40px; background-color: #f8f9fa; color: #343a40; }
        .form-container { background-color: #fff; padding: 35px; border-radius: 8px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); max-width: 500px; margin: 0 auto; }
        h1 { margin-top: 0; color: #28a745; text-align: center; border-bottom: 2px solid #28a745; padding-bottom: 10px; margin-bottom: 25px; }
        .form-group { margin-bottom: 20px; }
        label { display: block; margin-bottom: 8px; font-weight: bold; color: #495057; }
        input[type="text"], input[type="number"], select { width: 100%; padding: 12px; border: 1px solid #ced4da; border-radius: 5px; box-sizing: border-box; font-size: 16px; background-color: #fff;}
        input:focus, select:focus { border-color: #28a745; outline: none; box-shadow: 0 0 5px rgba(40, 167, 69, 0.5); }
        .btn-submit { display: block; width: 100%; padding: 14px; background-color: #28a745; color: white; border: none; border-radius: 5px; font-size: 16px; font-weight: bold; cursor: pointer; transition: background-color 0.2s; margin-top:30px;}
        .btn-submit:hover { background-color: #218838; }
        .back-link { display: block; text-align: center; margin-top: 20px; color: #6c757d; text-decoration: none; font-weight:bold; }
        .back-link:hover { text-decoration: underline; color: #343a40; }
    </style>
</head>
<body>

    <div class="form-container">
        <h1>Register Student</h1>

        <form asp-action="Add" asp-controller="Student" method="post">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label asp-for="Student.Name">Full Legal Name:</label>
                <input asp-for="Student.Name" type="text" required placeholder="Ex. John Doe" />
            </div>

            <div class="form-group">
                <label asp-for="Student.Age">Age:</label>
                <input asp-for="Student.Age" type="number" required min="10" max="100" placeholder="Student's Age" />
            </div>

            <div class="form-group">
                <label asp-for="Student.DepartmentId">Assign Department:</label>
                <select asp-for="Student.DepartmentId" asp-items="Model.Departments" required>
                    <option value="">-- Choose Target Department --</option>
                </select>
            </div>

            <button type="submit" class="btn-submit">Commit Registration</button>
        </form>

        <a asp-action="GetAll" class="back-link">Abandon Registration (Back)</a>
    </div>

</body>
</html>
