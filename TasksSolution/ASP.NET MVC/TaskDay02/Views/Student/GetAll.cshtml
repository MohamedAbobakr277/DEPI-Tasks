@model EFCoreTask.ViewModels.StudentIndexViewModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>All Students (Directory)</title>
    <style>
        body { font-family: 'Segoe UI', sans-serif; margin: 40px; background-color: #f8f9fa; color: #343a40; }
        h1 { border-bottom: 2px solid #007bff; padding-bottom: 10px; }
        .filter-panel { background: #fff; padding: 20px; border-radius: 8px; box-shadow: 0 4px 8px rgba(0,0,0,0.1); margin-bottom: 25px; display: flex; gap: 15px; align-items: flex-end; }
        .form-group { display: flex; flex-direction: column; flex: 1; }
        label { margin-bottom: 5px; font-weight: bold; color: #495057; }
        input[type="text"], select { padding: 10px; border: 1px solid #ced4da; border-radius: 4px; box-sizing: border-box; }
        .btn { padding: 10px 20px; text-decoration: none; border-radius: 5px; font-weight: bold; border: none; cursor: pointer; display: inline-block; }
        .btn-primary { background-color: #007bff; color: white; }
        .btn-success { background-color: #28a745; color: white; }
        .btn-warning { background-color: #ffc107; color: black; }
        .btn-danger { background-color: #dc3545; color: white; }
        .btn:hover { opacity: 0.9; }
        table { width: 100%; border-collapse: collapse; box-shadow: 0 4px 8px rgba(0,0,0,0.1); background-color: #fff; border-radius: 8px; overflow: hidden; }
        th, td { padding: 15px; text-align: left; border-bottom: 1px solid #dee2e6; }
        th { background-color: #007bff; color: white; }
        tr:last-child td { border-bottom: none; }
        .pagination { display: flex; list-style: none; padding: 0; margin-top: 25px; gap: 5px; }
        .page-link { padding: 8px 16px; background-color: #fff; border: 1px solid #dee2e6; color: #007bff; text-decoration: none; border-radius: 4px; }
        .page-item.active .page-link { background-color: #007bff; color: white; border-color: #007bff; }
        .page-link:hover { background-color: #e9ecef; }
    </style>
</head>
<body>
    <h1>Student Directory</h1>
    
    <div style="margin-bottom: 20px;">
        <a asp-action="Add" class="btn btn-success">➕ Add New Student</a>
    </div>

    <form method="get" asp-action="GetAll" class="filter-panel">
        <!-- Preserve Pagination State securely, resetting page to 1 during new query implicitly -->
        
        <div class="form-group">
            <label>Search by Name:</label>
            <input type="text" asp-for="SearchString" name="searchString" placeholder="Search student names..." />
        </div>
        
        <div class="form-group">
            <label>Filter by Department:</label>
            <select asp-for="SelectedDepartmentId" asp-items="Model.Departments" name="departmentId">
            </select>
        </div>

        <button type="submit" class="btn btn-primary" style="height: 42px;">🔍 Search & Filter</button>
        <a asp-action="GetAll" class="btn" style="background-color: #6c757d; color: white; margin-left: 10px; line-height: 22px;">Reset</a>
    </form>

    <table>
        <thead>
            <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Age</th>
                <th>Department</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Students != null && Model.Students.Any())
            {
                @foreach (var student in Model.Students)
                {
                    <tr>
                        <td>@student.Id</td>
                        <td>@student.Name</td>
                        <td>@student.Age</td>
                        <td>@(student.Department?.Name ?? "Unassigned")</td>
                        <td>
                            <a asp-action="GetById" asp-route-id="@student.Id" class="btn btn-primary" style="padding: 6px 12px; font-size: 14px;">View</a>
                            <a asp-action="Edit" asp-route-id="@student.Id" class="btn btn-warning" style="padding: 6px 12px; font-size: 14px;">Edit</a>
                            <a asp-action="Delete" asp-route-id="@student.Id" class="btn btn-danger" style="padding: 6px 12px; font-size: 14px;">Delete</a>
                        </td>
                    </tr>
                }
            } else {
                <tr><td colspan="5" style="text-align:center; padding: 20px;">No students match your query.</td></tr>
            }
        </tbody>
    </table>

    <!-- Pagination Controller -->
    @if (Model.TotalPages > 1)
    {
        <ul class="pagination">
            @for (int p = 1; p <= Model.TotalPages; p++)
            {
                <li class="page-item @(p == Model.CurrentPage ? "active" : "")">
                    <a asp-action="GetAll" 
                       asp-route-page="@p" 
                       asp-route-searchString="@Model.SearchString" 
                       asp-route-departmentId="@Model.SelectedDepartmentId" 
                       class="page-link">
                        @p
                    </a>
                </li>
            }
        </ul>
    }
</body>
</html>
