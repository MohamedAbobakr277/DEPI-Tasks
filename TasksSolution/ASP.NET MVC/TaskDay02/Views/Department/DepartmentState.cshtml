@model EFCoreTask.ViewModels.DepartmentStateViewModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Department State - @Model.DepartmentName</title>
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; margin: 40px; background-color: #f8f9fa; color: #343a40; }
        .card { background-color: #fff; padding: 25px; border-radius: 8px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); max-width: 600px; margin: 0 auto; }
        h1 { margin-top: 0; color: #007bff; border-bottom: 2px solid #007bff; padding-bottom: 10px; }
        .detail-row { margin-bottom: 20px; font-size: 16px; }
        .detail-label { font-weight: bold; width: 160px; display: inline-block; color: #6c757d; }
        select { padding: 10px; border-radius: 5px; border: 1px solid #ced4da; width: 100%; max-width: 300px; font-size: 16px; background-color: #fff; }
        select:focus { border-color: #007bff; outline: none; }
        .state-badge { padding: 6px 12px; border-radius: 20px; font-weight: bold; color: white; display: inline-block; font-size: 14px; }
        .state-main { background-color: #28a745; }
        .state-branch { background-color: #6c757d; }
        .back-link { display:inline-block; margin-top:20px; padding:10px 15px; background:#007bff; color:white; text-decoration:none; border-radius:5px; font-weight:bold; }
        .back-link:hover { background-color: #0056b3; }
    </style>
</head>
<body>
    <div class="card">
        <h1>Department State Overview</h1>
        
        <div class="detail-row">
            <span class="detail-label">Department Name:</span> @Model.DepartmentName
        </div>

        <div class="detail-row">
            <span class="detail-label">Department State:</span> 
            <span class="state-badge @(Model.DepartmentState == "Main" ? "state-main" : "state-branch")">
                @Model.DepartmentState
            </span>
        </div>

        <div class="detail-row">
            <span class="detail-label" style="display:block; margin-bottom: 10px;">Students Over 25:</span>
            @if (Model.StudentsOver25 != null && Model.StudentsOver25.Any())
            {
                <select asp-items="Model.StudentsOver25">
                    <option value="">-- View Students (Over 25) --</option>
                </select>
            }
            else
            {
                <span style="color: #dc3545; font-style: italic; background-color: #f8d7da; padding: 8px 12px; border-radius: 4px; display: inline-block;">
                    No students strictly over 25 years old are enrolled in this department.
                </span>
            }
        </div>

        <a href="/Department/ShowAll" class="back-link">Back to Departments</a>
    </div>
</body>
</html>
