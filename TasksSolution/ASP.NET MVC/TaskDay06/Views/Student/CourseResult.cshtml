@model EFCoreTask.ViewModels.StudentCourseResultViewModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Course Result For Student</title>
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; margin: 40px; background-color: #f8f9fa; color: #343a40; }
        .container { background-color: #fff; padding: 35px; border-radius: 8px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); max-width: 600px; margin: 0 auto; }
        h1 { margin-top: 0; color: #17a2b8; border-bottom: 2px solid #17a2b8; padding-bottom: 10px; margin-bottom: 25px; }
        .result-item { font-size: 18px; margin-bottom: 15px; }
        .result-label { font-weight: bold; width: 150px; display: inline-block; color: #495057;}
        .grade-highlight { font-weight: bold; font-size: 24px; padding: 5px 10px; border-radius: 4px; }
        .btn-secondary { background-color: #6c757d; color: white; padding: 10px 15px; text-decoration: none; border-radius: 5px; font-weight: bold; display: inline-block;}
        .btn-secondary:hover { opacity: 0.9; }
    </style>
</head>
<body>
    <div class="container">
        <h1>Grade Evaluation</h1>

        <div class="result-item">
            <span class="result-label">Student Name:</span>
            <span>@Model.StudentName</span>
        </div>

        <div class="result-item">
            <span class="result-label">Course Name:</span>
            <span>@Model.CourseName</span>
        </div>

        <div class="result-item">
            <span class="result-label">Degree:</span>
            <!-- Explicitly using the ColorCode from ViewModel so no conditions are needed here -->
            <span class="grade-highlight" style="color: @Model.ColorCode;">
                @Model.Grade
            </span>
        </div>

        <div style="margin-top: 30px; border-top: 1px solid #ced4da; padding-top: 20px;">
            <a asp-action="GetAll" class="btn-secondary">Back to Students List</a>
        </div>
    </div>
</body>
</html>
