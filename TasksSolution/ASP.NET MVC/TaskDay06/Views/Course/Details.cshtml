@model EFCoreTask.Models.Course
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Course Details</title>
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; margin: 40px; background-color: #f8f9fa; color: #343a40; }
        .container { background-color: #fff; padding: 35px; border-radius: 8px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); max-width: 600px; margin: 0 auto; }
        h1 { margin-top: 0; color: #17a2b8; border-bottom: 2px solid #17a2b8; padding-bottom: 10px; margin-bottom: 25px; }
        .detail-row { margin-bottom: 15px; font-size: 16px; }
        .detail-label { font-weight: bold; width: 150px; display: inline-block; color: #495057; }
        .btn { padding: 10px 15px; border-radius: 5px; text-decoration: none; color: white; font-weight: bold; margin-right: 10px; display: inline-block; }
        .btn-secondary { background-color: #6c757d; }
        .btn-warning { background-color: #ffc107; color: #212529; }
        .actions { margin-top: 30px; border-top: 1px solid #ced4da; padding-top: 20px; }
    </style>
</head>
<body>
    <div class="container">
        <h1>Course Details</h1>

        <div class="detail-row">
            <span class="detail-label">ID:</span> @Model.Id
        </div>
        <div class="detail-row">
            <span class="detail-label">Name:</span> @Model.Name
        </div>
        <div class="detail-row">
            <span class="detail-label">Degree:</span> @Model.Degree
        </div>
        <div class="detail-row">
            <span class="detail-label">Min Degree:</span> @Model.MinDegree
        </div>
        <div class="detail-row">
            <span class="detail-label">Department:</span> @(Model.Department?.Name ?? "N/A")
        </div>

        <div class="actions">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit Course</a>
            <a asp-action="Index" class="btn btn-secondary">Back to List</a>
        </div>
    </div>
</body>
</html>
