@model EFCoreTask.Models.Course
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Delete Course</title>
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; margin: 40px; background-color: #f8f9fa; color: #343a40; }
        .container { background-color: #fff; padding: 35px; border-radius: 8px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); max-width: 600px; margin: 0 auto; border-top: 5px solid #dc3545; }
        h1 { margin-top: 0; color: #dc3545; font-size: 24px; margin-bottom: 10px; }
        .warning-text { color: #856404; background-color: #fff3cd; padding: 15px; border-radius: 5px; margin-bottom: 25px; border: 1px solid #ffeeba; }
        .detail-row { margin-bottom: 10px; font-size: 16px; }
        .detail-label { font-weight: bold; width: 150px; display: inline-block; color: #495057; }
        .btn { padding: 10px 15px; border-radius: 5px; text-decoration: none; color: white; font-weight: bold; margin-right: 10px; display: inline-block; border: none; cursor: pointer; font-size: 16px; }
        .btn-danger { background-color: #dc3545; }
        .btn-secondary { background-color: #6c757d; }
        .btn:hover { opacity: 0.9; }
        .actions { margin-top: 30px; padding-top: 20px; border-top: 1px solid #ced4da; }
    </style>
</head>
<body>
    <div class="container">
        <h1>Delete Course</h1>
        <div class="warning-text">
            <strong>Warning:</strong> Are you sure you want to delete this course? This action cannot be undone.
        </div>

        <div class="detail-row">
            <span class="detail-label">Name:</span> @Model.Name
        </div>
        <div class="detail-row">
            <span class="detail-label">Degree:</span> @Model.Degree
        </div>
        <div class="detail-row">
            <span class="detail-label">Min Degree:</span> @Model.MinDegree
        </div>
        <div class="detail-row">
            <span class="detail-label">Department:</span> @(Model.Department?.Name ?? "N/A")
        </div>

        <div class="actions">
            <form asp-action="Delete" method="post" style="display:inline;">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />
                <button type="submit" class="btn btn-danger">Confirm Delete</button>
            </form>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </div>
    </div>
</body>
</html>
